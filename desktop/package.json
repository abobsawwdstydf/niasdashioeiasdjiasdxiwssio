{
  "name": "nexo-desktop",
  "version": "1.0.0",
  "description": "Nexo Messenger Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "messenger",
    "chat",
    "desktop"
  ],
  "author": "Nexo Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.nexo.messenger",
    "productName": "Nexo Messenger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    }
  }
}
