{
  "name": "nexo-desktop",
  "version": "1.0.0",
  "description": "Nexo Messenger - Modern Real-time Messaging",
  "main": "main.js",
  "author": "Nexo Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.nexo.messenger",
    "productName": "Nexo Messenger",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**"
    ],
    "extraResources": [
      {
        "from": "build/*.*",
        "to": "resources"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Nexo-Messenger-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "Nexo Messenger",
      "include": "build/installer.nsh",
      "language": "1049",
      "languages": ["1033", "1049"],
      "installerHeaderIcon": "build/icon.ico",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteInstallDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "unicode": true,
      "warningsAsErrors": false,
      "customize": {
        "title": "Nexo Messenger Setup",
        "welcome": "Welcome to Nexo Messenger - Modern Real-time Messaging",
        "install": "Installing Nexo Messenger...",
        "finish": "Installation Complete!"
      }
    }
  }
}
