{
  "name": "nexo-messenger-android",
  "version": "1.0.0",
  "description": "Nexo Messenger для Android",
  "scripts": {
    "build:web": "cd ../../apps/server/web && npm run build",
    "init:android": "cap init nexo-messenger com.nexo.messenger --web-dir ../../apps/server/web/dist",
    "add:android": "cap add android",
    "sync:android": "cap sync android",
    "open:android": "cap open android",
    "build:apk": "npm run build:web && npm run sync:android && cd android && ./gradlew assembleDebug",
    "build:release": "npm run build:web && npm run sync:android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/cli": "^5.7.0"
  }
}
