# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://host:port
REDIS_SESSION_URL=redis://host:port

# ============================================
# JWT
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# SERVER
# ============================================
PORT=3001
NODE_ENV=production
CORS_ORIGINS=*

# ============================================
# NEXO AI - CEREBRAS API (Приоритет №1)
# 4 аккаунта для балансировки
# ============================================
CEREBRAS_KEY_1=your-cerebras-key-1
CEREBRAS_KEY_2=your-cerebras-key-2
CEREBRAS_KEY_3=your-cerebras-key-3
CEREBRAS_KEY_4=your-cerebras-key-4

# ============================================
# NEXO AI - GROQ API (Приоритет №2)
# ============================================
GROQ_KEY_1=your-groq-key-1
GROQ_KEY_2=your-groq-key-2
GROQ_KEY_3=your-groq-key-3
GROQ_KEY_4=your-groq-key-4

# ============================================
# NEXO AI - SAMBANOVA API (Приоритет №3)
# ============================================
SAMBANOVA_KEY_1=your-sambanova-key-1
SAMBANOVA_KEY_2=your-sambanova-key-2
SAMBANOVA_KEY_3=your-sambanova-key-3
SAMBANOVA_KEY_4=your-sambanova-key-4

# ============================================
# NEXO AI - OPENROUTER API (Приоритет №4)
# ============================================
OPENROUTER_KEY_1=your-openrouter-key-1
OPENROUTER_KEY_2=your-openrouter-key-2
OPENROUTER_KEY_3=your-openrouter-key-3
OPENROUTER_KEY_4=your-openrouter-key-4
