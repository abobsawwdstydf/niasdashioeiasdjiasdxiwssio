generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  username         String   @unique
  displayName      String   @default("")
  email            String?  @unique
  phone            String?
  phoneVerified    Boolean  @default(false)
  emailVerified    Boolean  @default(false)
  password         String
  avatar           String?
  bio              String?
  birthday         String?
  createdAt        DateTime @default(now())
  lastSeen         DateTime @default(now())
  isOnline         Boolean  @default(false)
  hideStoryViews   Boolean  @default(false)
  registrationIp   String?
  pushSubscription String? // Web Push subscription (JSON string)
  pinnedChannelId  String? // Закреплённый канал
  notifyAll        Boolean  @default(true)
  notifyMessages   Boolean  @default(true)
  notifyCalls      Boolean  @default(true)
  notifyFriends    Boolean  @default(true)

  // 2FA login verification
  twoFASecret  String? // For TOTP-based 2FA (future)
  twoFAEnabled Boolean @default(false)
  twoFAMethod  String? // 'telegram' | 'email' | 'call'

  // Verification & badges
  isVerified        Boolean   @default(false)
  verifiedBadgeUrl  String? // Custom badge URL (photo/video/gif)
  verifiedBadgeType String? // 'default' | 'image' | 'video' | 'gif' | 'url'
  verifiedAt        DateTime?

  // User tag (admin-assigned)
  tagText  String? // Tag label e.g. "Staff", "VIP", "Developer"
  tagColor String? // Hex color e.g. "#ff6b6b" or preset name
  tagStyle String? // 'solid' | 'outline' | 'gradient' | 'glow'

  // Premium subscription
  isPremium     Boolean   @default(false)
  premiumUntil  DateTime? // When premium expires
  premiumType   String? // '1month' | '3months' | '6months' | '12months'
  beavers       Int       @default(0) // Currency balance (1 beaver = 1 ruble)
  totalSpent    Int       @default(0) // Total beavers spent
  totalEarned   Int       @default(0) // Total beavers earned

  // Ban system
  isBanned     Boolean   @default(false)
  banReason    String?
  banExpiresAt DateTime? // null = permanent ban
  bannedAt     DateTime?
  bannedBy     String? // Admin user ID

  // E2E Encryption (Signal Protocol)
  identityKey     String? // Public identity key
  signedPreKey    String? // Signed pre-key
  signedPreKeyId  Int?
  signedPreKeySig String? // Signature
  oneTimePreKeys  String? // JSON array of one-time pre-keys

  // Device sync
  devices UserDevice[]
  syncKey String? // Master sync key (encrypted)

  messages            Message[]
  chatMembers         ChatMember[]
  reactions           Reaction[]
  pollVotes           PollVote[]
  readReceipts        ReadReceipt[]
  forwardedMessages   Message[]         @relation("ForwardedFrom")
  stories             Story[]
  storyViews          StoryView[]
  friendshipsSent     Friendship[]      @relation("FriendshipsSent")
  friendshipsReceived Friendship[]      @relation("FriendshipsReceived")
  callerCalls         CallLog[]         @relation("CallerCalls")
  calleeCalls         CallLog[]         @relation("CalleeCalls")
  pinnedChannel       Chat?             @relation("PinnedChannels", fields: [pinnedChannelId], references: [id])
  uploadedFiles       TelegramFile[]
  uploadedLocalFiles  LocalFile[]
  verifiedEntities    VerifiedEntity[]  @relation("VerifiedBy")
  bansIssued          UserBan[]         @relation("BansIssued")
  mentions            Mention[]
  typingIndicators    TypingIndicator[]
}

model Chat {
  id          String   @id @default(uuid())
  type        String   @default("personal") // personal, group, channel
  name        String?
  username    String?  @unique
  avatar      String?
  description String?
  createdAt   DateTime @default(now())

  // Verification for channels/groups
  isVerified        Boolean   @default(false)
  verifiedBadgeUrl  String?
  verifiedBadgeType String?
  verifiedAt        DateTime?

  // Secret chat with password
  isSecret       Boolean @default(false)
  secretPassword String? // Hashed password for secret chat

  // E2E Encryption
  isE2E         Boolean @default(false)
  e2eSessionKey String? // Encrypted session key

  // Group/Channel settings
  slowModeInterval Int?    @default(0) // Seconds between messages (0 = disabled)
  welcomeMessage   String? // Welcome message for new members
  rules            String? // Group/channel rules
  subscribersCount Int     @default(0) // For channels

  // Permissions
  canMembersPost   Boolean @default(true) // For channels: can members post or only admins
  canMembersInvite Boolean @default(true) // Can members invite others

  // Webhooks for channels (Stage 3)
  webhookUrl    String? // Webhook URL for channel events
  webhookSecret String? // Secret for webhook verification
  webhookEvents String? // JSON array of enabled events: ["message", "member_join", "member_leave"]

  // Channel customization (Stage 3)
  customIcon       String? // Custom channel icon
  customColor      String? // Custom channel color
  customBackground String? // Custom channel background

  members          ChatMember[]
  messages         Message[]
  pinnedMessages   PinnedMessage[]
  pinnedByUsers    User[]            @relation("PinnedChannels")
  threads          Thread[]
  typingIndicators TypingIndicator[]
  webhooks         Webhook[]
  autoResponders   AutoResponder[]
  chatFolders      ChatFolder[]      @relation("FolderChats")
  chatTags         ChatTag[]

  @@index([type])
  @@index([subscribersCount])
}

model ChatMember {
  id         String    @id @default(uuid())
  chatId     String
  userId     String
  role       String    @default("member") // owner, admin, moderator, member, guest
  joinedAt   DateTime  @default(now())
  isMuted    Boolean   @default(false)
  isArchived Boolean   @default(false)
  isPinned   Boolean   @default(false)
  clearedAt  DateTime?

  // Permissions for this member
  canPost   Boolean @default(true)
  canInvite Boolean @default(true)
  canPin    Boolean @default(false)
  canDelete Boolean @default(false)

  // Slow mode tracking
  lastMessageAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId, isPinned])
  @@index([userId, isArchived])
  @@index([chatId, role])
}

model Message {
  id              String    @id @default(uuid())
  chatId          String
  senderId        String
  content         String?
  type            String    @default("text")
  replyToId       String?
  quote           String?
  quoteSelection  String? // Selected part of quoted message
  forwardedFromId String?
  isEdited        Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  editedAt        DateTime? // When message was edited

  // Video note fields
  videoUrl   String? // URL for video_note type
  duration   Int? // Duration in seconds for video_note
  thumbnail  String? // Thumbnail URL for video_note

  // E2E Encryption
  isEncrypted      Boolean @default(false)
  encryptedContent String? // Encrypted message content
  senderKeyId      String? // Key ID used for encryption

  // Thread support
  threadId String?
  thread   Thread? @relation("ThreadMessages", fields: [threadId], references: [id], onDelete: SetNull)

  // Self-destructing messages (Stage 3)
  selfDestructTimer Int? // Seconds until message self-destructs (null = no timer)
  selfDestructAt    DateTime? // When message will be deleted

  // Privacy settings (Stage 3)
  canForward    Boolean @default(true) // Can this message be forwarded
  canScreenshot Boolean @default(true) // Can screenshot be taken (for secret chats)

  chat          Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender        User      @relation(fields: [senderId], references: [id])
  replyTo       Message?  @relation("Reply", fields: [replyToId], references: [id])
  replies       Message[] @relation("Reply")
  forwardedFrom User?     @relation("ForwardedFrom", fields: [forwardedFromId], references: [id])

  media         Media[]
  reactions     Reaction[]
  pollVotes     PollVote[]
  readBy        ReadReceipt[]
  pinnedIn      PinnedMessage[]
  hiddenBy      HiddenMessage[]
  views         MessageView[]
  threadOrigins Thread[]        @relation("ThreadOrigin")
  mentions      Mention[]

  @@index([chatId, createdAt])
  @@index([senderId, chatId])
  @@index([scheduledAt])
}

model MessageView {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  deviceId  String? // For tracking unique devices
  viewedAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, deviceId])
}

model Media {
  id             String  @id @default(uuid())
  messageId      String
  type           String
  url            String
  filename       String?
  thumbnail      String?
  size           Int?
  duration       Float?
  width          Int?
  height         Int?
  telegramFileId String? // Reference to TelegramFile if stored in Telegram
  localFileId    String? // Reference to LocalFile if stored locally

  message      Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  telegramFile TelegramFile? @relation(fields: [telegramFileId], references: [id])
  localFile    LocalFile?    @relation(fields: [localFileId], references: [id])
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model PollVote {
  id          String   @id @default(uuid())
  messageId   String
  userId      String
  optionIndex Int // Which option was voted (0-based)
  votedAt     DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, optionIndex])
  @@index([messageId])
}

model ReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([readAt])
}

model PinnedMessage {
  id        String   @id @default(uuid())
  chatId    String
  messageId String
  pinnedAt  DateTime @default(now())

  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([chatId, messageId])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("text")
  mediaUrl  String?
  content   String?
  bgColor   String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  // Highlights
  isHighlight    Boolean @default(false)
  highlightTitle String?
  highlightCover String? // Cover image for highlight

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  views     StoryView[]
  reactions StoryReaction[]
  replies   StoryReply[]

  @@index([userId])
  @@index([expiresAt])
  @@index([isHighlight])
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([viewedAt])
}

// Story reactions (emoji)
model StoryReaction {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
}

// Story replies (DM)
model StoryReply {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([userId])
}

model HiddenMessage {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  hiddenAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("pending") // pending | accepted | declined
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("FriendshipsSent", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipsReceived", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId, status])
  @@index([friendId, status])
}

model CallLog {
  id        String   @id @default(uuid())
  callerId  String
  calleeId  String?
  chatId    String?
  type      String   @default("voice") // voice | video | group
  status    String   @default("completed") // completed | missed | declined | failed
  duration  Float    @default(0) // in seconds
  createdAt DateTime @default(now())

  caller User  @relation("CallerCalls", fields: [callerId], references: [id], onDelete: Cascade)
  callee User? @relation("CalleeCalls", fields: [calleeId], references: [id], onDelete: Cascade)
}

// Verified entities (users, channels, groups)
model VerifiedEntity {
  id         String   @id @default(uuid())
  entityType String // 'user' | 'channel' | 'group'
  entityId   String // User.id or Chat.id
  badgeUrl   String? // Custom badge URL (default: built-in blue check)
  badgeType  String   @default("default") // 'default' | 'image' | 'video' | 'gif' | 'url'
  verifiedBy String // Admin user ID
  verifiedAt DateTime @default(now())
  note       String? // Admin note

  user User? @relation("VerifiedBy", fields: [verifiedBy], references: [id])

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([verifiedBy])
}

// User ban history
model UserBan {
  id        String    @id @default(uuid())
  userId    String // Banned user
  reason    String
  expiresAt DateTime? // null = permanent
  bannedBy  String // Admin who issued ban
  createdAt DateTime  @default(now())
  isActive  Boolean   @default(true)
  liftedAt  DateTime?
  liftedBy  String?

  user User @relation("BansIssued", fields: [bannedBy], references: [id])

  @@index([userId])
  @@index([bannedBy])
  @@index([isActive])
}

// Threads (replies to messages)
model Thread {
  id        String   @id @default(uuid())
  chatId    String
  messageId String   @unique // The message this thread is based on
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat     Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message  Message   @relation("ThreadOrigin", fields: [messageId], references: [id], onDelete: Cascade)
  messages Message[] @relation("ThreadMessages")

  @@index([chatId])
  @@index([messageId])
}

// Telegram file storage metadata
model TelegramFile {
  id              String   @id @default(uuid())
  fileId          String   @unique // Unique file identifier
  userId          String // Owner user ID
  originalName    String // Original filename
  mimeType        String // File MIME type
  totalSize       Int // Total file size in bytes
  encryptionLevel Int      @default(2) // 0=none, 1=basic, 2=standard, 3=max
  createdAt       DateTime @default(now())
  lastAccessed    DateTime @default(now())
  accessCount     Int      @default(0)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks FileChunk[]
  media  Media[]

  @@index([userId])
  @@index([fileId])
}

model FileChunk {
  id             String   @id @default(uuid())
  fileId         String // Reference to TelegramFile.fileId
  telegramFileId String // Foreign key to TelegramFile
  chunkIndex     Int // Chunk order (0-based)
  channelId      Int // Telegram channel ID (1-4)
  messageId      Int // Telegram message ID
  botId          Int // Telegram bot ID (1-14)
  size           Int // Chunk size in bytes
  createdAt      DateTime @default(now())

  telegramFile TelegramFile @relation(fields: [telegramFileId], references: [id], onDelete: Cascade)

  @@unique([telegramFileId, chunkIndex])
  @@index([fileId])
  @@index([telegramFileId])
}

// Verification codes for phone, email, and 2FA login
model VerificationCode {
  id        String   @id @default(uuid())
  phone     String? // Phone number being verified
  email     String? // Email being verified
  userId    String? // For 2FA login — existing user
  code      String // 6-digit verification code
  purpose   String // 'phone_register' | 'email_register' | 'login_2fa'
  method    String // 'telegram' | 'call' | 'email' | 'sms'
  token     String? // Unique token for Telegram verification link
  expiresAt DateTime // Code expiration time (5 minutes)
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([phone])
  @@index([email])
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// Local file storage metadata
model LocalFile {
  id              String   @id @default(uuid())
  fileId          String   @unique // Unique file identifier (local_*)
  userId          String // Owner user ID
  originalName    String // Original filename
  mimeType        String // File MIME type
  totalSize       Int // Total file size in bytes
  storagePath     String // Path to file or first chunk
  encryptionLevel Int      @default(0) // 0=none, 1=basic, 2=standard, 3=max
  createdAt       DateTime @default(now())
  lastAccessed    DateTime @default(now())
  accessCount     Int      @default(0)

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks LocalFileChunk[]
  media  Media[]

  @@index([userId])
  @@index([fileId])
}

model LocalFileChunk {
  id          String   @id @default(uuid())
  fileId      String // Reference to LocalFile.fileId
  localFileId String // Foreign key to LocalFile
  chunkIndex  Int // Chunk order (0-based)
  path        String // File system path to chunk
  size        Int // Chunk size in bytes
  createdAt   DateTime @default(now())

  localFile LocalFile @relation(fields: [localFileId], references: [id], onDelete: Cascade)

  @@unique([localFileId, chunkIndex])
  @@index([fileId])
  @@index([localFileId])
}

// User devices for multi-device sync
model UserDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String   @unique // Unique device identifier
  deviceName String // "Chrome on Windows", "iPhone 13"
  deviceType String // "web", "mobile", "desktop"
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())

  // E2E keys for this device
  identityKey  String
  signedPreKey String
  preKeyId     Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
}

// Mentions in messages (@username)
model Mention {
  id        String   @id @default(uuid())
  messageId String
  userId    String // Mentioned user
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

// Typing indicators
model TypingIndicator {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  startedAt DateTime @default(now())
  expiresAt DateTime // Auto-expire after 5 seconds

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([expiresAt])
}

// Sticker packs and stickers
model StickerPack {
  id          String   @id @default(uuid())
  name        String
  description String?
  creatorId   String
  thumbnail   String? // Pack thumbnail
  isPublic    Boolean  @default(true)
  isAnimated  Boolean  @default(false)
  createdAt   DateTime @default(now())

  stickers Sticker[]

  @@index([creatorId])
  @@index([isPublic])
}

model Sticker {
  id         String   @id @default(uuid())
  packId     String
  emoji      String? // Associated emoji
  fileUrl    String // Sticker image/animation URL
  fileSize   Int
  width      Int?
  height     Int?
  isAnimated Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  pack StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
}

// GIF library
model Gif {
  id          String   @id @default(uuid())
  title       String?
  url         String
  thumbnail   String?
  width       Int?
  height      Int?
  size        Int?
  tags        String? // Comma-separated tags
  searchCount Int      @default(0) // Track popularity
  createdAt   DateTime @default(now())

  @@index([tags])
  @@index([searchCount])
}

// Hashtags for search
model Hashtag {
  id         String   @id @default(uuid())
  tag        String   @unique // Without # symbol
  useCount   Int      @default(0)
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  messages MessageHashtag[]

  @@index([tag])
  @@index([useCount])
}

model MessageHashtag {
  id        String   @id @default(uuid())
  messageId String
  hashtagId String
  createdAt DateTime @default(now())

  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([messageId, hashtagId])
  @@index([hashtagId])
  @@index([messageId])
}

// Stage 3: Webhooks for channels
model Webhook {
  id              String    @id @default(uuid())
  chatId          String
  url             String
  secret          String? // Secret for webhook verification
  events          String    @default("[]") // JSON array of enabled events
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  lastTriggeredAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

// Stage 3: Auto-responders for offline mode
model AutoResponder {
  id          String   @id @default(uuid())
  chatId      String
  userId      String
  trigger     String // Keyword or pattern to trigger response
  response    String // Auto-response message
  isActive    Boolean  @default(true)
  onlyOffline Boolean  @default(true) // Only respond when user is offline
  createdAt   DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([userId])
}

// Stage 3: Chat folders
model ChatFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  icon      String? // Emoji or icon
  color     String? // Folder color
  order     Int      @default(0)
  createdAt DateTime @default(now())

  chats Chat[] @relation("FolderChats")

  @@index([userId])
}

// Stage 3: Chat tags
model ChatTag {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  tag       String
  color     String? // Tag color
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId, tag])
  @@index([userId])
}

// Stage 3: User privacy settings
model UserPrivacySettings {
  id               String   @id @default(uuid())
  userId           String   @unique
  hideOnline       Boolean  @default(false)
  hideTyping       Boolean  @default(false)
  hideReadReceipts Boolean  @default(false)
  allowForwarding  Boolean  @default(true)
  allowScreenshots Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

// Stage 3: Chat customization
model ChatCustomization {
  id               String   @id @default(uuid())
  chatId           String   @unique
  userId           String
  customColor      String? // Custom chat color
  customBackground String? // Custom background image URL
  customSound      String? // Custom notification sound
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

// Stage 3: Priority contacts
model PriorityContact {
  id        String   @id @default(uuid())
  userId    String
  contactId String
  priority  Int      @default(0) // Higher = more priority
  createdAt DateTime @default(now())

  @@unique([userId, contactId])
  @@index([userId])
}

// Stage 3: Quick replies
model QuickReply {
  id        String   @id @default(uuid())
  userId    String
  shortcut  String // Shortcut text (e.g., "/hello")
  message   String // Full message to send
  createdAt DateTime @default(now())

  @@unique([userId, shortcut])
  @@index([userId])
}

// Stage 3: Chat statistics
model ChatStatistics {
  id           String   @id @default(uuid())
  chatId       String
  userId       String
  messageCount Int      @default(0)
  mediaCount   Int      @default(0)
  lastActive   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([chatId, userId])
  @@index([userId])
}

// Premium purchases history
model PremiumPurchase {
  id          String   @id @default(uuid())
  userId      String
  months      Int // 1, 3, 6, or 12
  beavers     Int // Amount paid in beavers
  purchasedAt DateTime @default(now())
  expiresAt   DateTime // When this premium period expires

  @@index([userId])
  @@index([purchasedAt])
}

// Transaction history for beavers
model Transaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int // Positive for earning, negative for spending
  type        String // 'purchase' | 'admin_add' | 'admin_remove' | 'premium' | 'gift' | 'refund'
  description String? // Transaction description
  relatedId   String? // Related entity ID (e.g., premium purchase ID)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
